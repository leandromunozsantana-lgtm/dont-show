# Ngrok authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=3DvBpNQQa15bQWawHastdx7DdhS_7VKW9ZBcd11h3q33syavb

# Ngrok account API key (https://dashboard.ngrok.com/api-keys).
# Distinto al authtoken: este permite matar endpoints/tunnel_sessions remotos
# vía https://api.ngrok.com para que un nuevo run.sh pueda "sobreponer" un
# túnel ya activo en otra máquina sin esperar el heartbeat de ~60s.
NGROK_API_KEY=3DvC6RCb8XqGd5j3Hwb1MpjvRlk_4pQ5mwmTj2FrLty9xW9o3

# API key que los clientes externos deben usar para acceder al tunnel
PROXY_API_KEY=admin

# Clave interna que se envía a las APIs reales (por defecto: skills-network)
# INTERNAL_API_KEY=skills-network

# Targets (por defecto se usan las URLs reales)
# ANTHROPIC_TARGET=https://api.anthropic.com
# OPENAI_TARGET=https://api.openai.com

# Puerto del proxy local (por defecto: 8080)
# PROXY_PORT=8080
